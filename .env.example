# ============================================
# GameConveyor — Environment Variables
# Copy this to .env and fill in values
# ============================================

# Database (Docker handles this automatically)
DATABASE_URL=postgresql://gameconveyor:gc_secret_password_change_me@localhost:5432/gameconveyor
DB_PASSWORD=gc_secret_password_change_me

# App
NEXTAUTH_SECRET=change_me_in_production
NEXTAUTH_URL=http://localhost:3000

# GitHub (for game repo management)
GITHUB_TOKEN=
